# NEXT_PUBLIC_API_BASE_URL:
#   빈 문자열(기본) → apiFetch 상대 경로 호출 → Next.js 프록시 → https://api.ssaju.net
#   http://localhost:8080 → 로컬 백엔드 직접 연결 (MSW 또는 실제 서버)
NEXT_PUBLIC_API_BASE_URL=

# MSW 목업 서버 활성화 여부 (true/false)
NEXT_PUBLIC_USE_MOCK=false

NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# 서버 사이드 프록시용 백엔드 주소 (Next.js API routes에서 사용)
BACKEND_URL=

# Vercel 배포 보호 우회 토큰 (백엔드가 Vercel에 배포된 경우 403 에러 해결용)
# x-vercel-proxy 헤더로 모든 백엔드 요청에 자동 추가됨
VERCEL_BYPASS_TOKEN=

# 금융감독원 DART API 키 (https://opendart.fss.or.kr 에서 발급)
DART_API_KEY=

# 금융위원회 기업기본정보 API 키 (https://www.data.go.kr)
FSC_API_KEY=
